{
  "name": "@toolsconnector/sdk",
  "version": "0.3.20",
  "description": "In-process, bring-your-own-key TypeScript SDK generated from ToolsConnector bindings. Stripe (Tier-1, live-verified): byte-identical requests to the Python connector.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node test/e2e.ts && node test/github.e2e.ts",
    "prepublishOnly": "npm run build"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/sachinshelke/ToolsConnector.git",
    "directory": "sdks/typescript"
  },
  "keywords": [
    "stripe",
    "sdk",
    "toolsconnector",
    "api",
    "in-process",
    "typescript"
  ],
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
