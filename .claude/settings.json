{
    "permissions": {
        "allow": [
            "Read",
            "Edit",
            "Bash",
            "Bash(git commit *)",
            "Bash(git * main)",
            "Bash(*)",
            "WebSearch",
            "WebFetch(*)"
        ],
        "deny": [
            "Bash(git push *)",
            "Bash(sudo *)"
        ],
        "defaultMode": "bypassPermissions"
    }
}